# Postgres connection string (must point at a database with the pgvector extension enabled)
DATABASE_URL="postgresql+asyncpg://raguser:ragpass@localhost:5432/ragdb"

# OpenRouter API key — used for embeddings, query expansion, and chat generation
OPENROUTER_API_KEY="your-openrouter-api-key"

# Comma-separated list of allowed CORS origins, or "*" for all 
ALLOW_CORS="*"
